<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Peerly" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#4A4AE0</item>
        <item name="colorPrimaryVariant">#3333AA</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSurface">#13131E</item>
        <item name="colorOnSurface">#E0DFFF</item>
        <item name="android:windowBackground">#0E0E16</item>
        <item name="android:statusBarColor">#0E0E16</item>
        <item name="android:navigationBarColor">#13131E</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="editTextStyle">@style/EditTextStyle</item>
        <item name="android:editTextStyle">@style/EditTextStyle</item>
    </style>

    <style name="TabTextStyle" parent="TextAppearance.Design.Tab">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="EditTextStyle" parent="Widget.AppCompat.EditText">
        <item name="android:background">@drawable/input_bg</item>
        <item name="backgroundTint">@null</item>
    </style>

</resources>